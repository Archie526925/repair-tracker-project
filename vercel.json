{
  "installCommand": "pnpm install --frozen-lockfile",
  "buildCommand": "pnpm --filter @workspace/repair-tracker run build",
  "outputDirectory": "artifacts/repair-tracker/dist/public",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://repair-tracker-project.onrender.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
